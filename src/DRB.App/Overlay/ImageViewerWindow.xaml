<Window x:Class="DRB.App.Overlay.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="1280"
        Height="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        ShowInTaskbar="True"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseWheel="Window_MouseWheel"
        Loaded="Window_Loaded">
    <!-- Root Border - Deep background, 12px radius with shadow -->
    <Border Background="#0F0F0F" CornerRadius="12" Margin="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>
            
            <!-- Title bar — subtle background, draggable -->
            <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Title with filename -->
                    <TextBlock x:Name="TxtTitle" Text="Image Viewer" Foreground="#E1E1E1" 
                               FontSize="13" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="18,0"/>
                    
                    <!-- Zoom indicator -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtZoom" Text="100%" Foreground="#707070" FontSize="12"/>
                    </StackPanel>
                    
                    <!-- Control buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <!-- Zoom out -->
                        <Button Content="−" 
                                Width="28" Height="28" FontSize="16"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnZoomOut_Click"
                                ToolTip="Zoom Out">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Fit to window -->
                        <Button Content="⊡" 
                                Width="28" Height="28" FontSize="14"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnFit_Click"
                                ToolTip="Fit to Window"
                                Margin="4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Zoom in -->
                        <Button Content="+" 
                                Width="28" Height="28" FontSize="16"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnZoomIn_Click"
                                ToolTip="Zoom In">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Separator -->
                        <Border Width="1" Background="#333333" Margin="10,8"/>
                        
                        <!-- Minimize -->
                        <Button Content="▬" 
                                Width="28" Height="28" FontSize="12"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnMinimize_Click"
                                ToolTip="Minimize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Maximize/Restore -->
                        <Button x:Name="BtnMaximize" Content="☐" 
                                Width="28" Height="28" FontSize="12"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnMaximize_Click"
                                ToolTip="Maximize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#333333"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Close button -->
                        <Button Content="✕" 
                                Width="28" Height="28" FontSize="11"
                                Background="Transparent" Foreground="#919191"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnClose_Click"
                                ToolTip="Close"
                                Margin="4,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#C34141"/>
                                            <Setter Property="Foreground" Value="#E1E1E1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Image container with scroll viewer -->
            <Border Grid.Row="1" Background="#0A0A0A" ClipToBounds="True">
                <ScrollViewer x:Name="ImageScrollViewer" 
                              HorizontalScrollBarVisibility="Auto" 
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="Both">
                    <Grid x:Name="ImageContainer">
                        <!-- Image with transform -->
                        <Image x:Name="ViewerImage" 
                               Stretch="None"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               MouseLeftButtonDown="ViewerImage_MouseLeftButtonDown"
                               MouseLeftButtonUp="ViewerImage_MouseLeftButtonUp"
                               MouseMove="ViewerImage_MouseMove">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                            </Image.LayoutTransform>
                        </Image>
                    </Grid>
                </ScrollViewer>
            </Border>
            
            <!-- Bottom bar — info and controls -->
            <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="0,0,12,12">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- File info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtFilePath"
                                   Foreground="#505050" FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="500"/>
                        <TextBlock x:Name="TxtDimensions"
                                   Foreground="#606060" FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <!-- Navigation -->
                    <Button x:Name="BtnPrevious" Grid.Column="1"
                            Content="◀ Prev" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#2A2A2A"
                            Foreground="#909090"
                            BorderThickness="0"
                            Padding="12,6"
                            Cursor="Hand"
                            FontSize="11"
                            Click="BtnPrevious_Click"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                        <Setter Property="Foreground" Value="#E1E1E1"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#1A1A1A"/>
                                        <Setter Property="Foreground" Value="#404040"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Open with default button -->
                    <Button x:Name="BtnOpenDefault" Grid.Column="2"
                            Content="Open in Viewer ▶" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#446CCD"
                            Foreground="#E1E1E1"
                            BorderThickness="0"
                            Padding="14,6"
                            Cursor="Hand"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Click="BtnOpenDefault_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3250A0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#284080"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
