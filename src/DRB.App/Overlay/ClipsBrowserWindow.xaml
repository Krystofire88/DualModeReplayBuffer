<Window x:Class="DRB.App.Overlay.ClipsBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Title="Browse Clips"
        Width="1000"
        Height="650"
        MinWidth="800"
        MinHeight="500"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="MainBorder" CornerRadius="20" Background="#F21E1E1E" Padding="0" BorderBrush="#333333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="700"/>
            </Grid.ColumnDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="20,16,20,12">
                <TextBlock x:Name="TitleText" Text="Browse Clips" Foreground="White" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Padding="10,6" FontSize="14"
                        Background="{x:Null}" Foreground="#888888" Click="CloseButton_Click" ToolTip="Close (Escape)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- Path Bar -->
            <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="20,0,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="UpButton" Content="⬆" Grid.Column="0" Width="36" Height="36" 
                        Background="#2A2A2A" Foreground="White" Click="UpButton_Click" 
                        ToolTip="Go to parent folder" Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBox x:Name="PathTextBox" Grid.Column="1" Height="36" Background="#2A2A2A" 
                         Foreground="White" BorderThickness="0" Padding="12,8" FontFamily="Consolas" FontSize="13"
                         VerticalContentAlignment="Center"/>
            </Grid>
            
            <!-- File List -->
            <Border x:Name="FileListBorder" Grid.Row="2" Grid.Column="0" Margin="20,0,10,12" Background="#1A1A1A" CornerRadius="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="FileListBox" Background="Transparent" BorderThickness="0" 
                             SelectionMode="Single" MouseDoubleClick="FileListBox_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Margin" Value="4,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Size}" Foreground="#888888" FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>
            
            <!-- Splitter -->
            <GridSplitter Grid.Row="2" Grid.Column="1" Width="8" Background="Transparent" 
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
            
            <!-- Video Player Panel -->
            <Border x:Name="VideoPlayerBorder" Grid.Row="2" Grid.Column="2" Margin="0,0,20,12" 
                    Background="#1A1A1A" CornerRadius="12" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Video Display -->
                    <MediaElement x:Name="VideoPlayer" Grid.Row="0" 
                                  LoadedBehavior="Manual" 
                                  UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  MediaOpened="VideoPlayer_MediaOpened"
                                  MediaEnded="VideoPlayer_MediaEnded"
                                  MediaFailed="VideoPlayer_MediaFailed"/>
                    
                    <!-- Video Info -->
                    <StackPanel Grid.Row="1" Margin="12,8,12,4">
                        <TextBlock x:Name="VideoTitleText" Text="" Foreground="White" FontFamily="Segoe UI" 
                                   FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="VideoDurationText" Text="" Foreground="#888888" FontFamily="Segoe UI" 
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <!-- Video Controls -->
                    <Grid Grid.Row="2" Margin="12,0,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="PlayPauseButton" Grid.Column="0" Content="▶" Width="36" Height="36"
                                Background="#3A3A3A" Foreground="White" Click="PlayPauseButton_Click"
                                ToolTip="Play/Pause">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Slider x:Name="VideoProgressSlider" Grid.Column="1" Margin="10,0"
                                Minimum="0" Maximum="100" Value="0"
                                PreviewMouseDown="VideoProgressSlider_PreviewMouseDown"
                                PreviewMouseUp="VideoProgressSlider_PreviewMouseUp"
                                ValueChanged="VideoProgressSlider_ValueChanged"/>
                        
                        <Button x:Name="ClosePlayerButton" Grid.Column="2" Content="✕" Width="36" Height="36"
                                Background="#3A3A3A" Foreground="White" Click="ClosePlayerButton_Click"
                                ToolTip="Close player">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Status Bar -->
            <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="20,0,20,16">
                <TextBlock x:Name="StatusText" Text="" Foreground="#666666" FontFamily="Segoe UI" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OpenWithButton" Content="Open with..." Padding="10,6" Margin="0,0,8,0"
                            Background="#2A2A2A" Foreground="White" Click="OpenWithButton_Click"
                            ToolTip="Open with default application" Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="OpenExplorerBtn" Content="Open in Explorer" 
                            Padding="14,8" FontSize="12" Background="#2A2A2A" Foreground="White" 
                            Click="OpenExplorerBtn_Click" ToolTip="Open current folder in Windows Explorer">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
