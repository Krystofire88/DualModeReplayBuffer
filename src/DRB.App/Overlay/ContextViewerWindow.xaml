<Window x:Class="DRB.App.Overlay.ContextViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="1100"
        Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Topmost="False"
        ShowInTaskbar="True"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <!-- Root Border - Deep background, 12px radius -->
    <Border Background="#0F0F0F" CornerRadius="12" Margin="0" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>
            
            <!-- Title bar — subtle background, draggable -->
            <Border Grid.Row="0" Background="#16FFFFFF" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <!-- Title -->
                    <TextBlock Text="Context Viewer" Foreground="#E1E1E1" 
                               FontSize="13" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="18,0"/>
                    
                    <!-- Search box -->
                    <Border Width="230" Height="28"
                            Background="#222222" CornerRadius="7"
                            BorderThickness="1" BorderBrush="#1EFFFFFF">
                        <TextBox x:Name="TxtSearch" 
                                 Background="Transparent" Foreground="#E1E1E1"
                                 BorderThickness="0"
                                 Padding="10,0,10,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="12" CaretBrush="White"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Close button -->
                    <Button x:Name="BtnClose" Content="✕" 
                            HorizontalAlignment="Right" Margin="0,0,10,0"
                            Width="28" Height="28" FontSize="11"
                            Background="Transparent" Foreground="#919191"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#C34141"/>
                                        <Setter Property="Foreground" Value="#E1E1E1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Carousel container -->
            <Canvas x:Name="CarouselCanvas" Grid.Row="1" 
                    ClipToBounds="False"/>
            
            <!-- Bottom bar — subtle separator -->
            <Border Grid.Row="2" Background="#12FFFFFF" CornerRadius="0,0,12,12">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Timestamp -->
                    <TextBlock x:Name="TxtTimestamp" Grid.Column="0"
                               Foreground="#919191" FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    
                    <!-- App name and Window title -->
                    <StackPanel Grid.Column="1" 
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock x:Name="TxtAppName"
                                   Foreground="#5F9BE1" FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="TxtWindowTitle"
                                   Foreground="#505050" FontSize="10"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"/>
                    </StackPanel>
                    
                    <!-- Launch button -->
                    <Button x:Name="BtnLaunch" Grid.Column="2"
                            Content="▶ Open" 
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#446CCD"
                            Foreground="#E1E1E1"
                            BorderThickness="0"
                            Padding="14,6"
                            Cursor="Hand"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Click="BtnLaunch_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                        CornerRadius="7" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3250A0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#284080"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                        <Setter Property="Foreground" Value="#505050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
